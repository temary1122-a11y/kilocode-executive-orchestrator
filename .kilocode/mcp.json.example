{
    "_comment":  "Copy this file to mcp.json and fill in your API keys. Do not commit mcp.json with real keys.",
    "mcpServers":  {
                       "exa":  {
                                   "args":  [
                                                "-y",
                                                "exa-mcp-server"
                                            ],
                                   "env":  {
                                               "EXA_API_KEY":  ""
                                           },
                                   "command":  "npx"
                               },
                       "github":  {
                                      "args":  [
                                                   "-y",
                                                   "@modelcontextprotocol/server-github"
                                               ],
                                      "env":  {
                                                  "GITHUB_PERSONAL_ACCESS_TOKEN":  ""
                                              },
                                      "command":  "npx"
                                  },
                       "sequential-thinking":  {
                                                   "args":  [
                                                                "-y",
                                                                "@modelcontextprotocol/server-sequential-thinking"
                                                            ],
                                                   "env":  {

                                                           },
                                                   "command":  "npx"
                                               },
                       "memory":  {
                                      "args":  [
                                                   "-y",
                                                   "@modelcontextprotocol/server-memory"
                                               ],
                                      "env":  {

                                              },
                                      "command":  "npx"
                                  },
                       "context7":  {
                                        "args":  [
                                                     "-y",
                                                     "@upstash/context7-mcp"
                                                 ],
                                        "env":  {
                                                    "DEFAULT_MINIMUM_TOKENS":  ""
                                                },
                                        "command":  "npx"
                                    },
                       "tavily":  {
                                      "args":  [
                                                   "-y",
                                                   "@tavily/mcp"
                                               ],
                                      "env":  {
                                                  "TAVILY_API_KEY":  ""
                                              },
                                      "command":  "npx"
                                  },
                       "playwright":  {
                                          "args":  [
                                                       "-y",
                                                       "@playwright/mcp"
                                                   ],
                                          "env":  {

                                                  },
                                          "command":  "npx"
                                      }
                   }
}
